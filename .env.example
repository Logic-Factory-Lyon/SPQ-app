APP_NAME="SPQ"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://SPQ.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=SPQ_app
DB_USERNAME=SPQ_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.SPQ.app

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=SPQ_

MAIL_MAILER=smtp
MAIL_HOST=smtp.SPQ.app
MAIL_PORT=587
MAIL_USERNAME=noreply@SPQ.app
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@SPQ.app"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=pk_live_xxx
STRIPE_SECRET=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
CASHIER_CURRENCY=EUR
CASHIER_CURRENCY_LOCALE=fr_FR

OPENCLAW_BINARY=openclaw
OPENCLAW_POLL_INTERVAL=5
